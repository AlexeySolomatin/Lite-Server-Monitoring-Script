#!/usr/bin/env bash
#
# -----------------------------------------------------------------------------
# Lite Server Monitor (LSM)
# Main Command Line Interface
# -----------------------------------------------------------------------------

set -Eeuo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Load core library
source "${PROJECT_ROOT}/lib/core/common.sh"

#
# Execute command
#
run_command() {

    local command="$1"
    shift || true

    local command_file="${PROJECT_ROOT}/commands/${command}.sh"

    if [[ ! -f "${command_file}" ]]; then
        log_error "Unknown command: ${command}"
        echo
        source "${PROJECT_ROOT}/commands/help.sh"
        command_help
        exit 1
    fi

    # shellcheck source=/dev/null
    source "${command_file}"

    local function_name="command_${command}"

    if ! declare -F "${function_name}" >/dev/null; then
        log_error "Command implementation not found: ${function_name}"
        exit 1
    fi

    "${function_name}" "$@"
}

#
# Main
#
main() {

    local command="${1:-help}"

    case "${command}" in

        install|update|uninstall|doctor|status|report|version|help|config|modules)

            shift || true
            run_command "${command}" "$@"
            ;;

        -h|--help)

            run_command help
            ;;

        *)

            log_error "Unknown command: ${command}"
            echo
            run_command help
            exit 1
            ;;

    esac
}

main "$@"
