#!/usr/bin/env bash
# ==============================================================================
# Lite Server Monitor (LSM)
# Главный исполняемый CLI-файл управления
# Путь: bin/lsm (или /usr/local/bin/lsm)
# ==============================================================================

set -Eeuo pipefail


LSM_ROOT="/opt/lsm"

export LSM_ROOT



COMMAND="${1:-help}"

shift || true



case "${COMMAND}" in


    help|-h|--help)

        exec "${LSM_ROOT}/commands/help.sh"

    ;;


    modules)

        exec "${LSM_ROOT}/commands/modules.sh" "$@"

    ;;


    install)

        exec "${LSM_ROOT}/commands/install.sh" "$@"

    ;;


    uninstall)

        exec "${LSM_ROOT}/commands/uninstall.sh" "$@"

    ;;


    update)

        exec "${LSM_ROOT}/commands/update.sh" "$@"

    ;;


    status)

        exec "${LSM_ROOT}/commands/status.sh" "$@"

    ;;


    doctor)

        exec "${LSM_ROOT}/commands/doctor.sh" "$@"

    ;;


    report)

        exec "${LSM_ROOT}/commands/report.sh" "$@"

    ;;


    config)

        exec "${LSM_ROOT}/commands/config.sh" "$@"

    ;;


    version)

        exec "${LSM_ROOT}/commands/version.sh" "$@"

    ;;


    *)

        echo
        echo "Неизвестная команда: ${COMMAND}"
        echo

        exec "${LSM_ROOT}/commands/help.sh"

    ;;


esac
