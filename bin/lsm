#!/usr/bin/env bash
#
# -----------------------------------------------------------------------------
# Lite Server Monitor (LSM)
# Main CLI
# -----------------------------------------------------------------------------

set -Eeuo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Load core libraries
source "${PROJECT_ROOT}/lib/core/common.sh"

show_help() {
cat <<EOF
Lite Server Monitor ${PROJECT_VERSION}

Usage:
    lsm <command>

Commands:
    install        Install Lite Server Monitor
    update         Update Lite Server Monitor
    uninstall      Remove Lite Server Monitor
    doctor         Check installation
    status         Show current status
    report         Generate health report
    version        Show version
    help           Show this help

EOF
}

run_command() {
    local command="$1"
    shift || true

    local command_file="${PROJECT_ROOT}/commands/${command}.sh"

    if [[ ! -f "${command_file}" ]]; then
        log_error "Unknown command: ${command}"
        echo
        show_help
        exit 1
    fi

    source "${command_file}"
    main "$@"
}

main() {

    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    case "$1" in

        install|update|uninstall|doctor|status|report|version)

            local cmd="$1"
            shift

            run_command "${cmd}" "$@"
            ;;

        help|-h|--help)

            show_help
            ;;

        *)

            log_error "Unknown command: $1"
            echo
            show_help
            exit 1
            ;;

    esac

}

main "$@"
