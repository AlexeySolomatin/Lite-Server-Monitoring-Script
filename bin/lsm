#!/usr/bin/env bash
#
# -----------------------------------------------------------------------------
# Lite Server Monitor (LSM)
# Main CLI Entry Point
# -----------------------------------------------------------------------------

set -Eeuo pipefail

#
# Root directory
#

readonly LSM_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

#
# Core libraries
#

source "${LSM_ROOT}/lib/core/colors.sh"
source "${LSM_ROOT}/lib/core/logging.sh"
source "${LSM_ROOT}/lib/core/common.sh"

#
# Parse command
#

COMMAND="${1:-help}"

if [[ $# -gt 0 ]]; then
    shift
fi

#
# Execute command
#

case "${COMMAND}" in

    install)
        source "${LSM_ROOT}/installer/install.sh"
        ;;

    uninstall)
        source "${LSM_ROOT}/installer/uninstall.sh"
        ;;

    update)
        source "${LSM_ROOT}/installer/update.sh"
        ;;

    status)
        source "${LSM_ROOT}/commands/status.sh"
        ;;

    report)
        source "${LSM_ROOT}/commands/report.sh"
        ;;

    doctor)
        source "${LSM_ROOT}/commands/doctor.sh"
        ;;

    modules)
        source "${LSM_ROOT}/commands/modules.sh"
        ;;

    config)
        source "${LSM_ROOT}/commands/config.sh"
        ;;

    version)
        source "${LSM_ROOT}/commands/version.sh"
        ;;

    help|-h|--help)
        source "${LSM_ROOT}/commands/help.sh"
        ;;

    *)
        log_error "Unknown command: ${COMMAND}"
        echo
        source "${LSM_ROOT}/commands/help.sh"
        exit 1
        ;;

esac
